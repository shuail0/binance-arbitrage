# 币安 API 配置 (适用于所有策略: 现货 3 个 + 合约 1 个)
# 从 https://www.binance.com/en/my/settings/api-management 获取

# API Key
BINANCE_API_KEY=your-api-key-here

# Ed25519 私钥 PEM 文件的绝对路径 (不是 HMAC Secret)
# 币安 WS API 和请求签名要求使用 Ed25519 密钥
# 生成方式: openssl genpkey -algorithm Ed25519 -out private.pem
BINANCE_PRIVATE_KEY_PATH=/absolute/path/to/ed25519-private-key.pem

# 交易环境 (0=实盘, 1=模拟盘)
# 实盘和模拟盘需要使用对应环境的 API 密钥
# 模拟盘: https://demo.binance.com
BINANCE_DEMO=0
